# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token
CLIENT_ID=your_client_id
GUILD_ID=your_guild_id

# ── Faction ───────────────────────────────────────────────────────────────────
FACTION_CHANNEL=faction_channel_id
ALLIES_ROLE=allies_s1_role_id
AXIS_ROLE=axis_s1_role_id
ALLIES_S2_ROLE=allies_s2_role_id
AXIS_S2_ROLE=axis_s2_role_id

# ── Logging ───────────────────────────────────────────────────────────────────
ADMIN_LOG_CHANNEL=admin_log_channel_id

# ── Lineup ────────────────────────────────────────────────────────────────────
LINEUP_CHANNEL=lineup_channel_id
LINEUP_COMMAND_CHANNEL=channel_id_where_lineup_command_is_allowed

# ── Server Details ────────────────────────────────────────────────────────────
SERVER_DETAILS_CHANNEL=server_details_channel_id
# Per-server defaults (used by Post Server S1 / Post Server S2 buttons)
SERVER_S1_NAME=HCIA EU 1
SERVER_S1_PASSWORD=MWFTIME
SERVER_S2_NAME=HCIA EU 2
SERVER_S2_PASSWORD=MWFTIME
# Legacy single-server fallback (used when SERVER_S{1,2}_* are unset)
SERVER_NAME=HCIA EU 1
SERVER_PASSWORD=MWFTIME

# ── Nodes ─────────────────────────────────────────────────────────────────────
NODES_CHANNELS=channel_id_1,channel_id_2

# ── Map Rotation ──────────────────────────────────────────────────────────────
MAP_ROTATION_CHANNEL=map_rotation_channel_id

# ── Auto-reset schedule (default: Wednesday at 22:00 Warsaw) ──────────────────
# RESET_DAY=3   (0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat)
# RESET_HOUR=22

# ── Anti-spam: cooldown between faction swaps per user (seconds, default 20) ──
# FACTION_SWAP_COOLDOWN_SECONDS=20

# ── Cooldown between destructive admin actions per user (seconds, default 10) ─
# ADMIN_DESTRUCTIVE_COOLDOWN_SECONDS=10

# ── Debug (optional) ──────────────────────────────────────────────────────────
# LOG_LEVEL=debug
